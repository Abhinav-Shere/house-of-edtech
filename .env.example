# ----------------------------------------------------------------------------
# Database — PostgreSQL connection string
# Local docker example: postgresql://postgres:postgres@localhost:5432/lfe?schema=public
# Supabase / Neon / Vercel Postgres: paste the pooled connection string here.
# ----------------------------------------------------------------------------
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/lfe?schema=public"

# ----------------------------------------------------------------------------
# Auth.js (NextAuth v5)
# Generate with: openssl rand -base64 32
# ----------------------------------------------------------------------------
AUTH_SECRET="replace-me-with-a-32-byte-random-string"
# In production set this to your deployed URL, e.g. https://your-app.vercel.app
AUTH_URL="http://localhost:3000"

# ----------------------------------------------------------------------------
# Sync engine tuning (optional — sensible defaults baked in)
# ----------------------------------------------------------------------------
# Maximum accepted sync payload in bytes (defense against OOM). Default 1 MiB.
NEXT_PUBLIC_MAX_SYNC_BYTES=1048576
# Remote poll interval in ms while a document is open.
NEXT_PUBLIC_SYNC_POLL_MS=4000

# ----------------------------------------------------------------------------
# AI provider (optional add-on features). Leave blank to disable AI gracefully.
# Set ONE provider. OpenAI-compatible base URLs (Groq, Together, etc.) supported.
#   OpenAI:  AI_PROVIDER=openai   AI_API_KEY=sk-...   AI_MODEL=gpt-4o-mini
#   Groq:    AI_PROVIDER=groq     AI_API_KEY=gsk_...  AI_MODEL=llama-3.3-70b-versatile
#   Gemini:  AI_PROVIDER=gemini   AI_API_KEY=...      AI_MODEL=gemini-1.5-flash
# ----------------------------------------------------------------------------
AI_PROVIDER=
AI_API_KEY=
AI_MODEL=
